{
  "name": "@arraypress/waveform-playlist-react",
  "version": "0.2.0",
  "description": "React component wrapper for @arraypress/waveform-playlist — forwardRef-friendly, useEffect lifecycle, a declarative `tracks` array, typed props, and an imperative handle for playlist + chapter navigation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "react-component",
    "audio",
    "playlist",
    "chapters",
    "waveform",
    "player",
    "podcast",
    "course",
    "navigation",
    "tracklist",
    "audio-player",
    "waveform-visualization",
    "podcast-player"
  ],
  "author": "ArrayPress",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arraypress/waveform-playlist-react.git"
  },
  "bugs": {
    "url": "https://github.com/arraypress/waveform-playlist-react/issues"
  },
  "homepage": "https://waveformplayer.com",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/arraypress"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@arraypress/waveform-player": "^1.20.0",
    "@arraypress/waveform-playlist": "^1.3.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@arraypress/waveform-player": "^1.20.0",
    "@arraypress/waveform-playlist": "^1.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
